# reverseloom local configuration
# Copy to .env, or edit these values from the in-app configuration center.

# Model service (a vision-capable model is required)
MODEL_PROTOCOL=openai
MODEL_REASONING_EFFORT=
BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-key-here
MODEL=gpt-4o

# Browser and authenticated upstream tunnel
REVERSELOOM_BROWSER_PATH=
REVERSELOOM_PROXY_HOST=
REVERSELOOM_PROXY_PORT=
REVERSELOOM_PROXY_USERNAME=
REVERSELOOM_PROXY_PASSWORD=

# Cookie/login-state sharing across conversations: shared (default) | isolated
#   shared   = log in once, reuse the login in every conversation
#   isolated = each conversation keeps its own logins (e.g. multiple accounts)
REVERSELOOM_COOKIE_SCOPE=shared

# Model context capacity; compaction policy is system-owned
GRAPHLOOM_MODEL_CONTEXT_WINDOW=830000

# Storage and process
REVERSELOOM_DB_BACKEND=sqlite
REVERSELOOM_DB_PATH=
REVERSELOOM_DB_URL=
REVERSELOOM_LOG_LEVEL=INFO
